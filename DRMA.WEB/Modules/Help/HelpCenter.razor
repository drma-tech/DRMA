@page "/{culture}/help"
@inherits PageCore<HelpCenter>

<HeadComponent Title="Help Center" Description="@($"Get detailed guides, troubleshooting tips, FAQs, and contact support for {AppInfo.CompanyName}. Solve issues and discover features easily.")" Url=@($"/{Culture}/help") Index="false" />
<PageSectionComponent IsPageHeader="true" Title="Help Center" Description="@($"Get detailed guides, troubleshooting tips, FAQs, and contact support for {AppInfo.CompanyName}. Solve issues and discover features easily.")"></PageSectionComponent>

<PageSectionComponent Title="Troubleshooting">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(async () => { await JsRuntime.Utils().ShowCache(cts.Token); })">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Memory"></MudIcon>
                    Show Cache
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(async () => { await JsRuntime.Utils().ClearAllStorage(); })">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Clear"></MudIcon>
                    Clear App Data
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Company">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/company/about-us") rel="nofollow">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Business"></MudIcon>
                    About us
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href="mailto:contact@drma-tech.com" rel="nofollow">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Email"></MudIcon>
                    Contact us
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="More from DRMA Tech">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            @foreach (var product in AppInfo.Products)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudButton Variant="Variant.Filled" FullWidth="true" Href="@product.Url" Target="_blank" rel="noopener">
                        <MudImage Src="@product.Logo" Class="me-2" Style="width: 20px; vertical-align: top;" Alt="@product.Title" />
                        @product.Title
                    </MudButton>
                </MudItem>
            }
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>
