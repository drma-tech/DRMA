@using Microsoft.JSInterop
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

@implements IDisposable

@if (AppStateStatic.Breakpoint == Breakpoint.Sm) //mobile or tablet
{
    //todo: smaller footer
}
else if (AppStateStatic.Breakpoint > Breakpoint.Sm) //other bigger devices
{
    <MudDivider Class="@Css.Build().Small("mb").Raw("mt-10")"></MudDivider>
    <MudGrid Justify="Justify.Center" Style="overflow: auto;" Spacing="@Css.SpaceSmall">
        <MudItem xs="12" sm="3" md="2">
            <MudList T="string" Dense="true" Gutters="false">
                <MudListSubheader Gutters="false">
                    <MudText Color="Color.Secondary">
                        Company
                    </MudText>
                </MudListSubheader>
                <MudListItem Text="About us" Href=@($"/{Culture}/company/about-us") Class="py-0" rel="nofollow" />
            </MudList>
        </MudItem>
        <MudItem xs="12" sm="3" md="2">
            <MudList T="string" Dense="true" Gutters="false">
                <MudListSubheader Gutters="false">
                    <MudText Color="Color.Secondary">
                        Support
                    </MudText>
                </MudListSubheader>
                <MudListItem Text="Help Center" Href=@($"/{Culture}/help") Class="py-0" rel="nofollow" />
                <MudListItem Text="Contact" Href="mailto:contact@drma-tech.com" Class="py-0" rel="nofollow" />
            </MudList>
        </MudItem>
    </MudGrid>
}

<style>
    .mud-list-item-avatar {
        min-width: 40px;
    }
</style>

@code {
    private string Culture => Navigation.GetCulture();

    protected readonly CancellationTokenSource cts = new();

    protected override void OnInitialized()
    {
        AppStateStatic.BreakpointChanged.Subscribe(breakpoint => StateHasChanged(), cts.Token);
    }

    void IDisposable.Dispose()
    {
        cts.Cancel();
        cts.Dispose();
        GC.SuppressFinalize(this);
    }
}
